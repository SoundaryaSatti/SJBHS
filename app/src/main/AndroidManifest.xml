<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.integro.sjbhs">

    <uses-sdk tools:overrideLibrary="com.pierfrancescosoffritti.androidyoutubeplayer" />

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/sjbhs_bangalore_footer"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true"
        tools:ignore="GoogleAppIndexingWarning">
        <activity android:name="com.integro.sibhs.activities.CoverPhotosDetails" />
        <activity android:name="com.integro.sibhs.activities.CalenderActivity" />
        <activity android:name="com.integro.sibhs.activities.GoverningDetailsActivity" />
        <activity android:name="com.integro.sibhs.activities.GoverningBodyActivity" />
        <activity android:name="com.integro.sibhs.activities.NewsLetterActivity" />
        <activity android:name="com.integro.sibhs.activities.WebActivity" />
        <activity android:name="com.integro.sibhs.activities.NewsDetailsActivity" />
        <activity android:name="com.integro.sibhs.activities.CourseDetailsActivity" />
        <activity android:name="com.integro.sibhs.activities.Main2Activity" />
        <activity android:name="com.integro.sibhs.activities.MainActivity" />
        <activity
            android:name="com.integro.sibhs.activities.WelcomeActivity"
            android:label="@string/app_name"
            android:theme="@style/AppTheme.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>