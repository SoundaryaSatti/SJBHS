<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:weightSum="3">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="2">

            <View
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/colorBlue" />

            <View
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/colorYellow" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0sp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0sp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0sp"
                        android:layout_weight="1.5"
                        android:background="@color/colorYellow" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="0sp"
                        android:layout_weight="1.5"
                        android:scaleType="centerCrop"
                        android:src="@drawable/principal" />

                    <TextView
                        android:id="@+id/tvPrincipal"
                        android:layout_width="match_parent"
                        android:layout_height="0sp"
                        android:layout_weight="0.5"
                        android:gravity="center"
                        android:text="Principal"
                        android:fontFamily="@font/frankruhllibre_medium"
                        android:textColor="@color/colorWhite"
                        android:textSize="20dp" />

                </LinearLayout>


                <LinearLayout
                    android:layout_width="0sp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.5"
                        android:background="@color/colorBlue">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="20dp"
                            android:background="@color/colorWhite"
                            android:src="@drawable/sjbhs_bangalore_footer" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivcall"
                        android:layout_width="match_parent"
                        android:layout_height="0sp"
                        android:layout_weight="1"
                        android:src="@drawable/downloadcaller1" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginRight="5dp"
                        android:background="@android:color/white">

                    </View>

                    <ImageView
                        android:id="@+id/ivmail"
                        android:layout_width="match_parent"
                        android:layout_height="0sp"
                        android:layout_weight="1"
                        android:padding="5dp"
                        android:src="@drawable/mailicon" />
                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0sp"
                android:layout_weight="0.8"
                android:orientation="vertical"
                android:layout_marginRight="4dp"
                android:weightSum="2">

                <TextView
                    android:id="@+id/tvManagement"
                    android:layout_width="match_parent"
                    android:layout_height="0sp"
                    android:layout_marginBottom="9dp"
                    android:layout_weight="0.9"
                    android:background="@android:color/white"
                    android:gravity="center"
                    android:text="Management"
                    android:fontFamily="@font/frankruhllibre_medium"
                    android:textColor="@color/colorBlue"
                    android:textSize="20dp" />

                <TextView
                    android:id="@+id/tvGoverningbody"
                    android:layout_width="match_parent"
                    android:layout_height="0sp"
                    android:layout_weight="0.9"
                    android:layout_marginTop="5dp"
                    android:background="@android:color/white"
                    android:gravity="center"
                    android:text="Govering Body"
                    android:fontFamily="@font/frankruhllibre_medium"
                    android:textColor="@color/colorBlue"
                    android:textSize="20dp" />
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0sp"
                android:layout_weight="1.2"
                android:orientation="vertical"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0sp"
                    android:layout_weight="1.5"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0sp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:weightSum="2">

                        <ImageView
                            android:id="@+id/ivfacebook"
                            android:layout_width="match_parent"
                            android:layout_height="0sp"
                            android:layout_weight="1"
                            android:padding="12dp"
                            android:src="@drawable/downloadfacebook" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="5dp"
                            android:background="@android:color/white">

                        </View>

                        <ImageView
                            android:id="@+id/ivyoutube"
                            android:layout_width="match_parent"
                            android:layout_height="0sp"
                            android:layout_weight="1"
                            android:padding="35dp"
                            android:src="@drawable/youtube" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="0sp"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:padding="23dp"
                        android:src="@drawable/editdownload" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="0sp"
                    android:layout_weight="0.5"
                    android:background="@color/colorYellow"
                    android:fontFamily="@font/frankruhllibre_medium"
                    android:gravity="center"
                    android:text="SJBHS OBA"
                    android:textColor="@android:color/white"
                    android:textSize="25dp" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</FrameLayout>