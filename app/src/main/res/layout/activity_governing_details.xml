<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_image"
    tools:context="com.integro.sibhs.activities.GoverningDetailsActivity">



    <androidx.cardview.widget.CardView
        android:id="@+id/cvGoverningbody"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="5dp">
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imageViewgb"
                android:layout_width="match_parent"
                android:layout_height="300dp" />

            <TextView
                android:id="@+id/tvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center"
                android:paddingLeft="10sp"
                android:layout_marginTop="10dp"
                android:paddingBottom="10dp"
                android:text="Name"
                android:textSize="15sp"
                android:fontFamily="@font/frankruhllibre_medium"
                android:textAppearance="@style/CustomTextAppearance"
                android:textColor="@color/cardview_dark_background"/>



            <TextView
                android:id="@+id/tvDesignation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center"
                android:paddingRight="10sp"
                android:text="Designation"
                android:paddingLeft="10dp"
                android:paddingBottom="10dp"
                android:textSize="13sp"
                android:fontFamily="@font/frankruhllibre_medium"
                android:textAppearance="@style/CustomTextAppearance"
                android:textColor="@color/cardview_dark_background"/>

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center"
                android:paddingLeft="10dp"
                android:paddingBottom="10dp"
                android:text="Description"
                android:textSize="13sp"
                android:fontFamily="@font/amiri_regular"
                android:textAppearance="@style/CustomTextAppearance"
                android:textColor="@color/cardview_dark_background"/>

        </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

</RelativeLayout>
