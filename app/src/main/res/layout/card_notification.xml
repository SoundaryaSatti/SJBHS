<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:id="@+id/crNotification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="8dp"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="5dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="3dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textSize="13sp"
                android:paddingRight="10sp"
                android:gravity="end|center"
                android:fontFamily="@font/frankruhllibre_medium"
                android:textAppearance="@style/CustomTextAppearance"
                android:textColor="@color/cardview_dark_background"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textSize="15sp"
                android:paddingLeft="10sp"
                android:fontFamily="@font/frankruhllibre_medium"
                android:gravity="start|center"
                android:textAppearance="@style/CustomTextAppearance"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1sp"
                android:layout_marginLeft="10sp"
                android:layout_marginRight="10sp"
                android:layout_marginTop="5sp"
                android:background="@android:color/holo_blue_dark" />

            <TextView
                android:id="@+id/tvTopicName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TipicName"
                android:layout_marginTop="5sp"
                android:textSize="13sp"
                android:fontFamily="@font/frankruhllibre_medium"
                android:paddingLeft="10sp"
                android:gravity="start|center"
                android:textAppearance="@style/CustomTextAppearance"
                android:textColor="@color/cardview_dark_background"/>
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Discription"
                android:paddingLeft="10sp"
                android:gravity="start|center"
                android:textAppearance="@style/CustomTextAppearance"
                android:textSize="13sp"
                android:fontFamily="@font/amiri_regular"
                android:textColor="@color/cardview_dark_background" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>