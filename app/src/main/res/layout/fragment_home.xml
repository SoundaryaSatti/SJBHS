<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:weightSum="3">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.7"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.9"
                    android:padding="13dp">

                    <!--
                                        <com.github.demono.AutoScrollViewPager
                    -->

                    <ImageView
                        android:id="@+id/vpCoverphoto"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.1"
                        android:scaleType="centerCrop"
                        android:src="@drawable/stjhighschool1" />

                    <!--
                                        </com.github.demono.AutoScrollViewPager>
                    -->
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.1"
                    android:orientation="vertical"
                    android:weightSum="2">

                    <TextView
                        android:id="@+id/tvLogin"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="10sp"
                        android:layout_marginBottom="10dp"
                        android:layout_weight="0.9"
                        android:background="@color/colorBlue"
                        android:fontFamily="@font/frankruhllibre_medium"
                        android:gravity="center"
                        android:text="Login"
                        android:textColor="@android:color/white"
                        android:textSize="20dp" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="2dp"
                        android:layout_weight="1.1">

                        <ImageView
                            android:id="@+id/iv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="15dp"
                            android:scaleType="fitStart"
                            android:src="@drawable/sjbhs_bangalore_footer"></ImageView>

                        <TextView
                            android:id="@+id/tvAdmission"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginBottom="10sp"
                            android:background="#EBFACD02"
                            android:fontFamily="@font/frankruhllibre_medium"
                            android:gravity="center"
                            android:text="Admission"
                            android:textColor="@android:color/white"
                            android:textSize="20dp" />

                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.6"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvNewsletter"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginBottom="5sp"
                        android:layout_weight="1"
                        android:background="@color/colorBlue"
                        android:fontFamily="@font/frankruhllibre_medium"
                        android:gravity="center|start"
                        android:paddingLeft="20sp"
                        android:text="News Letter"
                        android:textColor="@android:color/white"
                        android:textSize="20dp" />

                    <TextView
                        android:id="@+id/tvCalender"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="5dp"
                        android:layout_weight="1"
                        android:background="@color/colorGray"
                        android:fontFamily="@font/frankruhllibre_medium"
                        android:gravity="center|start"
                        android:paddingLeft="25sp"
                        android:text="Calender"
                        android:textColor="@android:color/white"
                        android:textSize="20dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <View
                        android:layout_width="0sp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.4" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="0sp"
                        android:layout_height="match_parent"
                        android:layout_margin="18sp"
                        android:layout_weight="0.6"
                        app:cardElevation="20sp">

                        <ImageView
                            android:id="@+id/cvImagelogo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/white"
                            android:elevation="50dp"
                            android:src="@drawable/sjbhs_bangalore_footer" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="0.9"
                android:orientation="vertical"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.4"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="bottom"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.github.demono.AutoScrollViewPager
                            android:id="@+id/vpNews"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:scaleType="centerCrop"
                            android:src="@drawable/news" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="bottom"
                            android:weightSum="2"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvNews"
                                android:layout_width="0sp"
                                android:layout_weight="1"
                                android:layout_height="45sp"
                                android:background="#928D8C8C"
                                android:fontFamily="@font/frankruhllibre_medium"
                                android:gravity="center"
                                android:text="News"
                                android:textColor="@android:color/white"
                                android:textSize="15sp" />
                            <View
                                android:layout_width="10dp"
                                android:layout_height="match_parent"
                                android:background="@android:color/white"/>

                        </LinearLayout>


                    </FrameLayout>



                </LinearLayout>

                <TextView

                    android:id="@+id/tvClubs"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:layout_weight="0.6"
                    android:background="@color/colorYellow"
                    android:fontFamily="@font/frankruhllibre_medium"
                    android:gravity="center"
                    android:text="Clubs"
                    android:textSize="20dp">

                </TextView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="1sp"
                android:layout_weight="0.8">

                <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
                    android:id="@+id/youtubeplayerview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:autoPlay="false"
                    app:showFullScreenButton="false"
                    app:showSeekBar="true"
                    app:showVideoCurrentTime="true"
                    app:showVideoDuration="true"
                    app:showYouTubeButton="true"
                    app:videoId="YxehHRJk3_U" />




            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</FrameLayout>